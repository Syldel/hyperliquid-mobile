{
  "name": "hyperliquid-mobile",
  "version": "0.0.0",
  "author": "Sylvain D.",
  "description": "Mobile application built with Ionic, Capacitor, and Angular, acting as a client for the Hyperliquid API.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration=$npm_config_configuration",
    "build": "ng build --configuration=$npm_config_configuration",
    "watch": "ng build --watch --configuration=$npm_config_configuration",
    "test": "ng test",
    "android:build": "npm run build -- --configuration=$npm_config_configuration && npx cap sync android",
    "android:build:apk": "sh scripts/android/build-android.sh apk $npm_config_configuration",
    "android:build:apk:debug": "sh scripts/android/build-android.sh debug $npm_config_configuration",
    "android:sync": "npx cap sync android",
    "android:run": "npx cap run android",
    "android:live": "sh scripts/android/live-reload.sh",
    "android:device": "sh scripts/android/build-android.sh debug development && adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json,css}\"",
    "postinstall": "npx capacitor-assets generate --android"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/preferences": "^8.0.1",
    "@ionic/angular": "^8.8.2",
    "@syldel/hl-shared-types": "^0.0.9",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "jwt-decode": "^4.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "^21.2.6",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2"
  }
}
